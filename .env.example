# VerifyAE — Environment Variables
# 1. Copy:  cp .env.example .env
# 2. Fill in your values
# 3. Never commit .env to git

# ── Required ─────────────────────────────────────────────────────────────────
# Free Groq key: https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_your_key_here

# ── Optional ─────────────────────────────────────────────────────────────────
# Live search uses DuckDuckGo — no API key needed, works out of the box
PORT=3001
ALLOWED_ORIGIN=*
ADMIN_KEY=change-this-to-a-random-string
